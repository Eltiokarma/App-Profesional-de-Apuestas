# ── Fuente de datos de la app ─────────────────────────────────────────────
# mock : motor local determinista (demo, no requiere backend)  ← default
# http : backend SAD real (FastAPI + PostgreSQL)
VITE_DATA_SOURCE=mock

# ── Backend SAD (solo aplica con VITE_DATA_SOURCE=http) ───────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Token bearer SOLO para entornos de desarrollo/staging.
# Debe coincidir con SAD_API_TOKEN del backend (ver backend/README.md).
# ⚠ Todo VITE_* queda embebido en el bundle (visible para cualquiera):
#   en producción la autenticación debe ser de sesión gestionada por el
#   backend, y la clave de API-Football NUNCA va en el frontend.
VITE_API_KEY=

# ── Intervalos (ms) ────────────────────────────────────────────────────────
VITE_POLL_HEALTH_MS=30000
VITE_POLL_LIVE_MS=60000

# ── Extractor de ingesta (backend/ingesta/extractor.py) ───────────────────
# Clave de API-Football vía RapidAPI. NO lleva prefijo VITE_ a propósito:
# solo la lee el extractor Python; nunca se embebe en el frontend.
API_FOOTBALL_KEY=
